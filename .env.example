# =============================================================================
# Finanças — App de Despesas Partilhadas — variáveis de ambiente
# Copia para .env.local e preenche. NUNCA commitar segredos reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth.js / NextAuth
# -----------------------------------------------------------------------------
# Segredo para assinar sessões/JWT. Gera um com: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# URL base da app (em produção: https://o-teu-dominio). Em dev pode ficar vazio.
# AUTH_URL="http://localhost:3000"

# Allow-list: SÓ estes emails conseguem entrar (separados por vírgula).
# Em dev, se não definires, assume "tiago@example.com,clara@example.com".
ALLOWED_EMAILS="tiago@example.com,clara@example.com"

# Login de desenvolvimento SEM SSO (entra como um dos emails da allow-list).
# DEIXA "false" OU REMOVE EM PRODUÇÃO.
AUTH_DEV_LOGIN="true"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Microsoft Entra ID / Azure AD (https://portal.azure.com → App registrations)
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Issuer: https://login.microsoftonline.com/<TENANT_ID>/v2.0  (ou "common")
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/common/v2.0"

# -----------------------------------------------------------------------------
# Modo de dados
# -----------------------------------------------------------------------------
# "mock"     → repositório em memória (app navegável sem Supabase). Bom para dev.
# "supabase" → usa o Supabase real (requer as chaves abaixo).
# Se não definires, usa "supabase" caso as chaves existam, senão "mock".
APP_DATA_MODE="mock"

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard → Project Settings → API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SÓ no servidor. NUNCA expor ao browser.
SUPABASE_SERVICE_ROLE_KEY=""
